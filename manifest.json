{
  "manifest_version": 3,
  "name": "PayTrace – Privacy-Preserving Payment Forensics Engine",
  "version": "1.0.0",
  "description": "Detects potentially suspicious behavior on online payment pages without collecting sensitive payment information.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "riskEngine.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PayTrace"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["reportGenerator.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
